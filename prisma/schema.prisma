generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////
// ENUMS
//////////////////////

enum RoleType {
  ADMIN
  MANAGER
  USER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELED
}

enum LeadStatus {
  LEAD
  CONTACTED
  QUALIFIED
  VISIT
  PROPOSAL
  WON
  LOST
}

enum Priority {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

//////////////////////
// CORE
//////////////////////

model School {
  id        String   @id @default(uuid())
  name      String
  shortName String?
  cnpj      String?  @unique
  address   String?
  phone     String?
  email     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  tasks            Task[]
  leads            Lead[]
  whatsappAccounts WhatsappAccount[]
  forms            Form[]

  @@map("schools")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      RoleType @default(USER)
  phone     String?
  avatarUrl String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  tasksAssigned Task[]         @relation("AssignedTasks")
  tasksCreated  Task[]         @relation("CreatedTasks")
  leadsAssigned Lead[]         @relation("AssignedLeads")
  comments      Comment[]
  notifications Notification[]
  formsCreated  Form[]         @relation("FormsCreated")

  @@map("users")
}

//////////////////////
// MODULES & PHASES
//////////////////////

model Module {
  id           String  @id @default(uuid())
  slug         String  @unique
  name         String
  description  String?
  color        String?
  colorLight   String?
  hasFinancial Boolean @default(false)
  displayOrder Int     @default(0)
  active       Boolean @default(true)

  phases     Phase[]
  categories Category[]
  tasks      Task[]

  @@map("modules")
}

model Phase {
  id       String  @id @default(uuid())
  slug     String
  name     String
  color    String?
  bgColor  String?
  slaDays  Int?
  isFinal  Boolean @default(false)
  position Int     @default(0)

  moduleId String
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  tasks Task[]

  @@unique([moduleId, slug])
  @@map("phases")
}

model Category {
  id       String @id @default(uuid())
  name     String
  position Int    @default(0)

  moduleId String
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  tasks Task[]

  @@unique([moduleId, name])
  @@map("categories")
}

//////////////////////
// TASKS (KANBAN)
//////////////////////

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  priority    Priority   @default(MEDIA)
  dueDate     DateTime?
  position    Int        @default(0)
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Financeiro (modulo compras)
  amount         Decimal?  @db.Decimal(12, 2)
  supplier       String?
  documentNumber String?
  paymentDue     DateTime?

  moduleId String
  module   Module @relation(fields: [moduleId], references: [id])

  phaseId String
  phase   Phase  @relation(fields: [phaseId], references: [id])

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  createdById String
  createdBy   User @relation("CreatedTasks", fields: [createdById], references: [id])

  assignedToId String?
  assignedTo   User?  @relation("AssignedTasks", fields: [assignedToId], references: [id])

  comments    Comment[]
  attachments Attachment[]
  history     TaskHistory[]

  @@index([moduleId])
  @@index([phaseId])
  @@index([schoolId])
  @@index([assignedToId])
  @@index([createdAt(sort: Desc)])
  @@map("tasks")
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  taskId String
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String
  user   User @relation(fields: [userId], references: [id])

  @@map("comments")
}

model Attachment {
  id        String   @id @default(uuid())
  fileName  String
  fileUrl   String
  fileSize  Int?
  mimeType  String?
  createdAt DateTime @default(now())

  taskId String
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("attachments")
}

model TaskHistory {
  id        String   @id @default(uuid())
  action    String
  details   String?
  userName  String
  createdAt DateTime @default(now())

  taskId String
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_history")
}

//////////////////////
// CRM (COMERCIAL)
//////////////////////

model Lead {
  id            String     @id @default(uuid())
  name          String?
  phone         String
  email         String?
  studentName   String?
  gradeInterest String?
  origin        String?
  status        LeadStatus @default(LEAD)
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  assignedToId String?
  assignedTo   User?  @relation("AssignedLeads", fields: [assignedToId], references: [id])

  conversations Conversation[]

  @@index([schoolId])
  @@index([status])
  @@map("leads")
}

//////////////////////
// WHATSAPP (BASE)
//////////////////////

model WhatsappAccount {
  id          String   @id @default(uuid())
  phoneNumber String
  name        String?
  createdAt   DateTime @default(now())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  conversations Conversation[]

  @@map("whatsapp_accounts")
}

model Conversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  leadId String
  lead   Lead @relation(fields: [leadId], references: [id])

  whatsappAccountId String?
  whatsappAccount   WhatsappAccount? @relation(fields: [whatsappAccountId], references: [id])

  messages Message[]

  @@map("conversations")
}

model Message {
  id        String           @id @default(uuid())
  content   String
  direction MessageDirection
  status    String?
  createdAt DateTime         @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@map("messages")
}

//////////////////////
// NOTIFICACOES
//////////////////////

model Notification {
  id        String   @id @default(uuid())
  title     String
  content   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

model EmailLog {
  id        String   @id @default(uuid())
  to        String
  subject   String
  content   String
  status    String
  createdAt DateTime @default(now())

  @@map("email_logs")
}

//////////////////////
// AUTOMACOES
//////////////////////

model AutomationRule {
  id        String   @id @default(uuid())
  name      String
  trigger   String
  action    String
  config    Json?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("automation_rules")
}

//////////////////////
// FORMULÁRIOS & INSCRIÇÕES
//////////////////////

enum FormStatus {
  DRAFT
  ACTIVE
  PAUSED
  CLOSED
  ARCHIVED
}

enum FieldType {
  TEXT
  TEXTAREA
  EMAIL
  PHONE
  CPF
  DATE
  NUMBER
  SELECT
  MULTISELECT
  RADIO
  CHECKBOX
  FILE
}

enum SubmissionStatus {
  RESERVED
  PENDING
  CONFIRMED
  WAITLIST
  CANCELED
  REJECTED
  EXPIRED
}

enum SlotMode {
  GLOBAL
  PER_OPTION
}

model Form {
  id          String     @id @default(uuid())
  title       String
  slug        String     @unique
  description String?
  coverImage  String?

  status      FormStatus @default(DRAFT)
  isPublic    Boolean    @default(true)

  opensAt     DateTime?
  closesAt    DateTime?

  slotMode    SlotMode   @default(GLOBAL)
  maxSlots    Int?

  reservationTtlMinutes Int  @default(0)
  requiresConfirmation  Boolean @default(false)

  confirmationSubject String?
  confirmationBody    String?

  currentVersion Int    @default(0)

  schoolId    String
  school      School     @relation(fields: [schoolId], references: [id])

  createdById String
  createdBy   User       @relation("FormsCreated", fields: [createdById], references: [id])

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  fields      FormField[]
  slotOptions FormSlotOption[]
  submissions Submission[]
  versions    FormVersion[]

  @@index([schoolId])
  @@index([status])
  @@index([slug])
  @@map("forms")
}

model FormField {
  id          String    @id @default(uuid())
  formId      String
  form        Form      @relation(fields: [formId], references: [id], onDelete: Cascade)

  label       String
  fieldKey    String
  type        FieldType
  placeholder String?
  helpText    String?

  required    Boolean   @default(false)
  position    Int       @default(0)
  config      Json?
  isSlotField Boolean   @default(false)

  values      SubmissionValue[]

  @@unique([formId, fieldKey])
  @@index([formId])
  @@map("form_fields")
}

model FormSlotOption {
  id       String @id @default(uuid())
  formId   String
  form     Form   @relation(fields: [formId], references: [id], onDelete: Cascade)

  label    String
  maxSlots Int
  filled   Int    @default(0)

  submissions Submission[]

  @@unique([formId, label])
  @@index([formId])
  @@map("form_slot_options")
}

model FormVersion {
  id          String   @id @default(uuid())
  formId      String
  form        Form     @relation(fields: [formId], references: [id], onDelete: Cascade)

  version     Int
  snapshot    Json
  publishedAt DateTime @default(now())
  publishedBy String?

  submissions Submission[]

  @@unique([formId, version])
  @@index([formId])
  @@map("form_versions")
}

model Submission {
  id          String           @id @default(uuid())
  formId      String
  form        Form             @relation(fields: [formId], references: [id])

  formVersionId String?
  formVersion   FormVersion? @relation(fields: [formVersionId], references: [id])

  protocol    String           @unique
  status      SubmissionStatus @default(PENDING)

  name        String
  email       String
  phone       String?
  cpf         String?

  ipAddress   String?
  userAgent   String?

  slotOptionId String?
  slotOption   FormSlotOption? @relation(fields: [slotOptionId], references: [id])

  reservedUntil DateTime?
  confirmedAt   DateTime?
  canceledAt    DateTime?
  expiredAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  values       SubmissionValue[]
  logs         SubmissionLog[]

  @@index([formId])
  @@index([status])
  @@index([protocol])
  @@index([email])
  @@index([cpf])
  @@index([createdAt(sort: Desc)])
  @@index([reservedUntil])
  @@map("submissions")
}

model SubmissionValue {
  id           String     @id @default(uuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  fieldId      String
  field        FormField  @relation(fields: [fieldId], references: [id])

  value        String
  fileUrl      String?

  @@unique([submissionId, fieldId])
  @@index([submissionId])
  @@map("submission_values")
}

model SubmissionLog {
  id           String     @id @default(uuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  action       String
  details      Json?
  createdAt    DateTime   @default(now())

  @@index([submissionId])
  @@index([createdAt(sort: Desc)])
  @@map("submission_logs")
}
